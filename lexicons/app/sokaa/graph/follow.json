{
  "lexicon": 1,
  "id": "app.sokaa.graph.follow",
  "defs": {
    "main": {
      "type": "record",
      "description": "Record declaring a follow relationship. Stored in the follower's repo; subject is the DID of the account being followed.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["subject", "createdAt"],
        "properties": {
          "subject": {
            "type": "string",
            "format": "did",
            "description": "The DID of the account being followed."
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
