{
  "lexicon": 1,
  "id": "app.bsky.embed.getEmbedExternalView",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get a hydrated view of an external embed for a given AT-URI.",
      "parameters": {
        "type": "params",
        "required": ["uri"],
        "properties": {
          "uri": {
            "type": "string",
            "format": "at-uri",
            "description": "AT-URI of the record whose external embed view should be returned. Example: a site.standard.document record."
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "app.bsky.embed.external#view"
        }
      }
    }
  }
}
