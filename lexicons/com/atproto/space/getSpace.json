{
  "lexicon": 1,
  "id": "com.atproto.space.getSpace",
  "defs": {
    "main": {
      "type": "query",
      "description": "Describe a space. Served by the space host. Returns the space URI plus an open-union `config` carrying host-implementation-specific configuration (e.g. com.atproto.simplespace.defs#spaceConfig). Clients that don't recognize the config variant should ignore it.",
      "parameters": {
        "type": "params",
        "required": ["space"],
        "properties": {
          "space": {
            "type": "string",
            "format": "space-uri",
            "description": "Reference to the space."
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["uri", "config"],
          "properties": {
            "uri": {
              "type": "string",
              "format": "space-uri",
              "description": "URI of the space."
            },
            "config": {
              "type": "union",
              "description": "Implementation-specific configuration for the space.",
              "refs": ["com.atproto.simplespace.defs#spaceConfig"]
            }
          }
        }
      },
      "errors": [{ "name": "SpaceNotFound" }]
    }
  }
}
