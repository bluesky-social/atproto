{
  "lexicon": 1,
  "id": "com.atproto.space.getSpaceCredential",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Exchange a member grant for a space credential. Called on the space owner's PDS. The grant is presented as the request's authorization token; the requesting service's endpoint is resolved from the grant issuer's DID document. The space credential can be used to read data from member PDSes.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["space"],
          "properties": {
            "space": {
              "type": "string",
              "format": "space-uri",
              "description": "Reference to the space."
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["credential"],
          "properties": {
            "credential": {
              "type": "string",
              "description": "A signed JWT space credential."
            }
          }
        }
      },
      "errors": [
        { "name": "SpaceNotFound" },
        { "name": "NotAMember" },
        { "name": "InvalidGrant" }
      ]
    }
  }
}
