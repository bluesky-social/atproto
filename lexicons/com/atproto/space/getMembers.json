{
  "lexicon": 1,
  "id": "com.atproto.space.getMembers",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get the member list for a space. Must be called on the space owner's PDS.",
      "parameters": {
        "type": "params",
        "required": ["space"],
        "properties": {
          "space": {
            "type": "string",
            "format": "uri",
            "description": "Reference to the space."
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["members"],
          "properties": {
            "members": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#member"
              }
            }
          }
        }
      },
      "errors": [
        {
          "name": "SpaceNotFound"
        }
      ]
    },
    "member": {
      "type": "object",
      "required": ["did", "addedAt"],
      "properties": {
        "did": {
          "type": "string",
          "format": "did"
        },
        "addedAt": {
          "type": "string",
          "format": "datetime"
        }
      }
    }
  }
}
