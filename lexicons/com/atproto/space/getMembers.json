{
  "lexicon": 1,
  "id": "com.atproto.space.getMembers",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get the member list for a space. Must be called on the space owner's PDS.",
      "parameters": {
        "type": "params",
        "required": ["space"],
        "properties": {
          "space": {
            "type": "string",
            "format": "space-uri",
            "description": "Reference to the space."
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 1000,
            "default": 100,
            "description": "Maximum number of members to return."
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["members"],
          "properties": {
            "cursor": {
              "type": "string"
            },
            "members": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#member"
              }
            }
          }
        }
      },
      "errors": [
        { "name": "SpaceNotFound" }
      ]
    },
    "member": {
      "type": "object",
      "required": ["did"],
      "properties": {
        "did": {
          "type": "string",
          "format": "did"
        }
      }
    }
  }
}
