{
  "lexicon": 1,
  "id": "com.atproto.space.removeMember",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Remove a member from a space. Requires auth as the space owner.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["space", "did"],
          "properties": {
            "space": {
              "type": "string",
              "format": "space-uri",
              "description": "Reference to the space."
            },
            "did": {
              "type": "string",
              "format": "did",
              "description": "The DID of the member to remove."
            }
          }
        }
      },
      "errors": [
        { "name": "SpaceNotFound" },
        { "name": "NotSpaceOwner" }
      ]
    }
  }
}
