{
  "lexicon": 1,
  "id": "com.atproto.sync.listReposByCollection",
  "defs": {
    "main": {
      "type": "query",
      "description": "Enumerates all the active DIDs which have records in any of the given collection NSIDs. If omitted, active DIDs from all collections are returned.",
      "parameters": {
        "type": "params",
        "required": [],
        "properties": {
          "collection": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "nsid"
            }
          },
          "limit": {
            "type": "integer",
            "description": "Maximum size of response set. Recommend setting a large maximum (1000+) when enumerating large DID lists.",
            "minimum": 1,
            "maximum": 2000,
            "default": 500
          },
          "cursor": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["repos"],
          "properties": {
            "cursor": { "type": "string" },
            "repos": {
              "type": "array",
              "items": { "type": "ref", "ref": "#repo" }
            }
          }
        }
      }
    },
    "repo": {
      "type": "object",
      "required": ["did"],
      "properties": {
        "did": { "type": "string", "format": "did" }
      }
    }
  }
}
