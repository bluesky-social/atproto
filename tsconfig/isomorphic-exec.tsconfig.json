{
  // @NOTE This tsconfig is used for TypeScript files that, when compiled, can
  // run in both Browser and NodeJS environments, and that needs to be
  // executable by NodeJS without being compiled.
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./isomorphic.tsconfig.json",
  "compilerOptions": {
    "noImplicitAny": true,
    "rewriteRelativeImportExtensions": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "target": "ES2023",
  },
}
