{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    // The use of "verbatimModuleSyntax" allows to make bundling, tree-shaking &
    // executing the code faster (through the elision of "import type"
    // statements from the runtime code tree). Adoption throughout this repo is
    // still a work in progress.
    "verbatimModuleSyntax": true,
  },
}
