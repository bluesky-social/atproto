{
  "name": "@atproto/bsync",
  "version": "0.0.26",
  "license": "MIT",
  "description": "Sychronizing service for app.bsky App View (Bluesky API)",
  "keywords": [
    "atproto",
    "bluesky"
  ],
  "homepage": "https://atproto.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/bluesky-social/atproto",
    "directory": "packages/bsync"
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "start": "node --enable-source-maps dist/bin.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules ../dev-infra/with-test-db.sh jest",
    "test:log": "tail -50 test.log | pino-pretty",
    "test:updateSnapshot": "jest --updateSnapshot",
    "migration:create": "ts-node ./bin/migration-create.ts",
    "buf:gen": "buf generate proto"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@atproto/common": "workspace:^",
    "@atproto/syntax": "workspace:^",
    "@bufbuild/protobuf": "^2.12.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-node": "^2.1.1",
    "http-terminator": "^3.2.0",
    "kysely": "^0.22.0",
    "pg": "^8.10.0",
    "pino-http": "^8.2.1",
    "typed-emitter": "^2.1.0"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.69.0",
    "@bufbuild/protoc-gen-es": "^2.12.0",
    "@types/pg": "^8.6.6",
    "get-port": "^5.1.1",
    "jest": "^30.0.0",
    "ts-node": "^10.8.2",
    "typescript": "^6.0.3"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  }
}
