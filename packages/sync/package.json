{
  "name": "@atproto/sync",
  "version": "0.3.3",
  "license": "MIT",
  "description": "atproto sync library",
  "keywords": [
    "atproto",
    "sync",
    "firehose",
    "relay"
  ],
  "homepage": "https://atproto.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/bluesky-social/atproto",
    "directory": "packages/sync"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "codegen": "lex build --clear --indexFile --lexicons ../../lexicons --include com.atproto.sync.subscribeRepos",
    "prebuild": "pnpm run codegen",
    "build": "tsgo --build tsconfig.build.json",
    "test": "NODE_OPTIONS=--experimental-vm-modules ../dev-infra/with-test-redis-and-db.sh jest"
  },
  "dependencies": {
    "@atproto/common": "workspace:^",
    "@atproto/identity": "workspace:^",
    "@atproto/lex": "workspace:^",
    "@atproto/repo": "workspace:^",
    "@atproto/syntax": "workspace:^",
    "@atproto/xrpc-server": "workspace:^",
    "p-queue": "^8.0.0",
    "ws": "^8.12.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.4",
    "jest": "^30.0.0"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  }
}
