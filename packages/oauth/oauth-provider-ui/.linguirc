{
  "format": "po",
  "sourceLocale": "en",
  "locales": [
    "en",
    "es",
    "fr",
    "ja"
  ],
  "fallbackLocales": {
    "default": "en"
  },
  "catalogs": [
    {
      "path": "<rootDir>/src/locales/{locale}/messages",
      "include": [
        "<rootDir>/src"
      ],
      "exclude": [
        "**/dist/**",
        "**/node_modules/**"
      ]
    }
  ]
}
